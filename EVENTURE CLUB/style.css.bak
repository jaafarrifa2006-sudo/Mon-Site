:root{--bg:#0b0b0b;--muted:#000;--gold:#d4af37;--accent:#fff;--card:#111;--radius:12px;--container:1100px;--gradient-primary:linear-gradient(135deg,#d4af37 0%,#f5d547 50%,#c9a961 100%);--shadow-glow:0 0 30px rgba(212,175,55,.3);--transition-smooth:all .4s cubic-bezier(.25,.46,.45,.94)}

*{scrollbar-width:thin;scrollbar-color:#d4af37 #111}*::-webkit-scrollbar{width:8px;height:8px}*::-webkit-scrollbar-track{background:#111}*::-webkit-scrollbar-thumb{background:#d4af37;border-radius:10px;transition:.3s ease}*::-webkit-scrollbar-thumb:hover{background:#e8c75b;box-shadow:0 0 10px rgba(212,175,55,.5)}
@media (max-width:480px){
.cards-4{grid-template-columns:1fr}
.container{padding:1rem}
.hero-text h1{font-size:1.4rem}
}
.team .cards-visual {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: space-between;
    align-items: flex-start;
}

.team .cards-visual .card {
    flex: 1 1 calc(33.333% - 16px); 
    max-width: calc(33.333% - 16px);
    box-sizing: border-box;
    text-align: center;
    padding: 8px;
}

.team .cards-visual .card .profile-img {
    width: 100%;
    height: 220px; 
    object-fit: cover;
    display: block;
    border-radius: 6px;
}

@media (max-width: 900px) {
    .team .cards-visual .card {
        flex: 1 1 calc(50% - 16px);
        max-width: calc(50% - 16px);
    }
}

@media (max-width: 520px) {
    .team .cards-visual .card {
        flex: 1 1 100%;
        max-width: 100%;
    }
}

.container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 16px;
    box-sizing: border-box;
}

img {
    max-width: 100%;
    height: auto;
    display: block;
}


.header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
}

.nav-toggle {
    display: none;
    background: transparent;
    border: none;
    font-size: 24px;
    cursor: pointer;
}


.main-nav {
    display: flex;
    gap: 12px;
    align-items: center;
}
@media (max-width: 800px) {
    .nav-toggle { display: block; }

    .main-nav {
        display: none;
        width: 100%;
        flex-direction: column;
        gap: 8px;
        margin-top: 8px;
    }
    .main-nav.open {
        display: flex;
    }

    .main-nav a {
        width: 100%;
        padding: 8px 10px;
        box-sizing: border-box;
    }
}


.hero .hero-inner {
    display: flex;
    align-items: center;
    gap: 24px;
}
@media (max-width: 900px) {
    .hero .hero-inner {
        flex-direction: column;
        align-items: stretch;
    }
    .hero-media {
        width: 100%;
    }
}


.grid.cards-4 {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
}
.grid.cards-4 .card {
    flex: 1 1 calc(25% - 16px);
    max-width: calc(25% - 16px);
    box-sizing: border-box;
}
@media (max-width: 900px) {
    .grid.cards-4 .card {
        flex: 1 1 calc(50% - 16px);
        max-width: calc(50% - 16px);
    }
}
@media (max-width: 520px) {
    .grid.cards-4 .card {
        flex: 1 1 100%;
        max-width: 100%;
    }
}


.team .cards-visual {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
}
.team .cards-visual .card {
    flex: 1 1 calc(33.333% - 12px);
    max-width: calc(33.333% - 12px);
    box-sizing: border-box;
    text-align: center;
}
.team .cards-visual .profile-img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 6px;
}
@media (max-width: 900px) {
    .team .cards-visual .card {
        flex: 1 1 calc(50% - 12px);
        max-width: calc(50% - 12px);
    }
}
@media (max-width: 520px) {
    .team .cards-visual .card {
        flex: 1 1 100%;
        max-width: 100%;
    }
}


@media (max-width: 520px) {
    h1 { font-size: 1.4rem; line-height: 1.2; }
    h2 { font-size: 1.1rem; }
    .hero-ctas { display: flex; flex-direction: column; gap: 8px; }
}



nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 15px 40px;
    background: #000; 
}

nav ul {
    display: flex;
    gap: 30px;
    list-style: none;
}

nav ul li a {
    color: #000000;          
    font-weight: 600;
    text-decoration: none;
    font-size: 17px;
    transition: 0.3s ease;  
    padding: 8px 12px;
    border-radius: 8px;      
}


nav ul li a:hover {
    color: #d4af37;         
    transform: scale(1.12); 
    background: rgba(255, 215, 0, 0.08); 
    box-shadow: 0 0 12px rgba(212, 175, 55, 0.4);
}


@media (max-width: 600px) {

    nav {
        padding: 12px 20px;
    }

    nav ul {
        gap: 18px;
    }

    nav ul li a {
        font-size: 15px;
        padding: 6px 8px;
    }
}

.main-nav a {
    position: relative;
    overflow: hidden;
    transition: 0.35s ease;
}

.main-nav a::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0%;
    height: 2px;
    background: var(--gold);
    transition: 0.35s ease;
    transform: translateX(-50%);
}

.main-nav a:hover {
    color: var(--gold);
    transform: translateY(-2px) scale(1.08);
    text-shadow: 0 0 8px rgba(212, 175, 55, 0.5);
}

.main-nav a:hover::after {
    width: 80%;
}

.btn:hover {
    background: #e8c75b;
    box-shadow: 0 0 12px rgba(212,175,55,0.45);
    transform: scale(1.06);
}

.btn-outline:hover,
.btn-ghost:hover {
    border-color: var(--gold);
    color: var(--gold);
    transform: scale(1.06);
    box-shadow: 0 0 10px rgba(212,175,55,0.3);
}


.card {
    transition: 0.35s ease, border-color 0.35s ease;
}

.card:hover {
    transform: translateY(-6px) scale(1.02);
    border-color: rgba(212,175,55,0.25);
    box-shadow: 0 0 18px rgba(212,175,55,0.18);
}


@media (max-width: 900px) {
    .main-nav a {
        padding: 0.6rem 0.8rem;
        font-size: 1rem;
    }
}

@media (max-width: 480px) {
    .main-nav a:hover {
        transform: scale(1.05);
    }
}

@keyframes goldGlow {
    0% { text-shadow: 0 0 6px rgba(212,175,55,0.4); }
    50% { text-shadow: 0 0 14px rgba(212,175,55,0.8); }
    100% { text-shadow: 0 0 6px rgba(212,175,55,0.4); }
}


h1, h2, h3 {
    animation: goldGlow 3s ease-in-out infinite;
}


.glass {
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 0 22px rgba(212,175,55,0.08);
}


.card {
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.1);
    transition: 0.35s ease;
}

.card:hover {
    transform: translateY(-5px) scale(1.03);
    box-shadow: 0 0 22px rgba(212,175,55,0.25);
    border-color: rgba(212,175,55,0.45);
}


.section-header {
    padding-bottom: 0.6rem;
    border-bottom: 2px solid rgba(212,175,55,0.35);
    margin-bottom: 1.4rem;
    display: inline-block;
}

.section-header::after {
    content: "";
    display: block;
    width: 45%;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), transparent);
    margin-top: 4px;
    border-radius: 10px;
}


@keyframes fadeUpGold {
    0% {
        opacity: 0;
        transform: translateY(20px);
        filter: blur(6px);
    }
    100% {
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
    }
}

.reveal {
    opacity: 0;
    animation: fadeUpGold 0.8s ease forwards;
}

.reveal-delay-1 { animation-delay: 0.15s; }
.reveal-delay-2 { animation-delay: 0.30s; }
.reveal-delay-3 { animation-delay: 0.45s; }


.main-nav a {
    position: relative;
    overflow: hidden;
    transition: 0.35s ease;
}

.main-nav a::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0%;
    height: 2px;
    background: var(--gold);
    transition: 0.35s ease;
    transform: translateX(-50%);
}

.main-nav a:hover {
    color: var(--gold);
    transform: translateY(-3px) scale(1.10);
    text-shadow: 0 0 10px rgba(212,175,55,0.7);
}

.main-nav a:hover::after {
    width: 90%;
}


.btn:hover {
    background: var(--gold);
    box-shadow: 0 0 18px rgba(212,175,55,0.55);
    transform: scale(1.07);
}

.btn-outline:hover,
.btn-ghost:hover {
    border-color: var(--gold);
    color: var(--gold);
    box-shadow: 0 0 14px rgba(212,175,55,0.45);
    transform: scale(1.08);
}


@keyframes shimmer {
    0% { background-position: -1000px 0; }
    100% { background-position: 1000px 0; }
}

@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
}

@keyframes pulse-glow {
    0%, 100% { 
        box-shadow: 0 0 20px rgba(212,175,55,0.3),
                    0 0 40px rgba(212,175,55,0.1);
    }
    50% { 
        box-shadow: 0 0 40px rgba(212,175,55,0.6),
                    0 0 80px rgba(212,175,55,0.2);
    }
}

@keyframes slide-up {
    from {
        opacity: 0;
        transform: translateY(60px) rotateX(-10deg);
    }
    to {
        opacity: 1;
        transform: translateY(0) rotateX(0);
    }
}

@keyframes rotate-border {
    0% { border-color: rgba(212,175,55,0.2); }
    50% { border-color: rgba(212,175,55,0.8); }
    100% { border-color: rgba(212,175,55,0.2); }
}

@keyframes particle-float {
    0% {
        opacity: 0;
        transform: translateY(100px) translateX(-50%);
    }
    10% {
        opacity: 1;
    }
    90% {
        opacity: 1;
    }
    100% {
        opacity: 0;
        transform: translateY(-100vh) translateX(-50%);
    }
}

@keyframes text-gradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

@keyframes aurora {
    0% { backdrop-filter: blur(8px) brightness(1); }
    50% { backdrop-filter: blur(12px) brightness(1.1); }
    100% { backdrop-filter: blur(8px) brightness(1); }
}



body {
    background: #000000;
    color: #f5f5f5;
    scroll-behavior: smooth;
    perspective: 1000px;
    min-height: 100vh;
}

html {
    background: #000000;
    scroll-behavior: smooth;
}

@supports (backdrop-filter: blur(10px)) {
    .glass {
        animation: aurora 4s ease-in-out infinite;
    }
}

.gradient-text {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: text-gradient 4s ease infinite;
    background-size: 200% 200%;
}

.float-element {
    animation: float 3s ease-in-out infinite;
}

.float-element-slow {
    animation: float 4s ease-in-out infinite;
}

.float-element-fast {
    animation: float 2s ease-in-out infinite;
}

.card {
    background: rgba(17, 17, 17, 0.6);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(212, 175, 55, 0.1);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: var(--transition-smooth);
    position: relative;
    overflow: hidden;
}

.card::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(212,175,55,0.1) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
}

.card:hover {
    transform: translateY(-12px) scale(1.04) rotateX(5deg);
    border-color: rgba(212, 175, 55, 0.4);
    box-shadow: var(--shadow-glow), 0 20px 40px rgba(212,175,55,0.15);
    background: rgba(17, 17, 17, 0.8);
}

.card:hover::before {
    opacity: 1;
}

.btn {
    position: relative;
    overflow: hidden;
    transition: var(--transition-smooth);
    border: 2px solid transparent;
}

.btn::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: rgba(255,255,255,0.2);
    transition: left 0.5s ease;
    z-index: -1;
}

.btn:hover::before {
    left: 100%;
}

.btn:hover {
    background: var(--gradient-primary);
    box-shadow: 0 0 30px rgba(212,175,55,0.5), 0 10px 30px rgba(212,175,55,0.2);
    transform: scale(1.08) translateY(-2px);
    letter-spacing: 1px;
}

.btn:active {
    transform: scale(0.96);
}

nav {
    position: relative;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(212, 175, 55, 0.1);
    box-shadow: 0 10px 40px rgba(0,0,0,0.5);
    transition: var(--transition-smooth);
}

nav:hover {
    border-bottom-color: rgba(212, 175, 55, 0.3);
}

nav ul li a {
    position: relative;
    background: linear-gradient(135deg, rgba(212,175,55,0), rgba(212,175,55,0));
    padding: 10px 16px;
    display: block;
    transition: var(--transition-smooth);
}

nav ul li a::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(212,175,55,0.2), rgba(245,213,71,0.1));
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
    border-radius: 8px;
}

nav ul li a:hover::before {
    opacity: 1;
}

nav ul li a:hover {
    color: #d4af37;
    transform: translateY(-4px) scale(1.15);
    background: rgba(212, 175, 55, 0.1);
    box-shadow: 0 8px 24px rgba(212, 175, 55, 0.3),
                inset 0 1px 0 rgba(255, 255, 255, 0.2);
    text-shadow: 0 0 12px rgba(212, 175, 55, 0.6);
    border-radius: 8px;
}

.main-nav a {
    position: relative;
    overflow: visible;
    transition: var(--transition-smooth);
}

.main-nav a::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 50%;
    width: 0%;
    height: 3px;
    background: linear-gradient(90deg, var(--gold), #f5d547);
    transition: width 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transform: translateX(-50%);
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
}

.main-nav a:hover::after {
    width: 100%;
}

.section-header {
    position: relative;
    padding: 0 0 1rem 0;
    border: none;
    display: inline-block;
    transition: var(--transition-smooth);
}

.section-header::before {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--gradient-primary);
    border-radius: 10px;
    animation: shimmer 2s infinite;
    background-size: 200% 100%;
}

.section-header::after {
    content: "";
    display: block;
    width: 0%;
    height: 4px;
    background: linear-gradient(90deg, var(--gold), transparent);
    margin-top: 8px;
    border-radius: 10px;
    transition: width 0.6s ease;
}

.section-header:hover::after {
    width: 60%;
}

.team .cards-visual .card {
    position: relative;
    transition: var(--transition-smooth);
}

.team .cards-visual .card:hover {
    transform: translateY(-15px) rotateY(10deg) scale(1.05);
}

.team .cards-visual .profile-img {
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    transition: var(--transition-smooth);
}

.team .cards-visual .profile-img::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(212,175,55,0.3), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
}

.team .cards-visual .card:hover .profile-img::after {
    opacity: 1;
}

.team .cards-visual .profile-img {
    filter: brightness(1);
    transition: var(--transition-smooth);
}

.team .cards-visual .card:hover .profile-img {
    filter: brightness(1.2) drop-shadow(0 0 20px rgba(212,175,55,0.4));
}

.reveal {
    opacity: 0;
    animation: slide-up 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
}

.reveal-delay-1 { animation-delay: 0.2s; }
.reveal-delay-2 { animation-delay: 0.4s; }
.reveal-delay-3 { animation-delay: 0.6s; }
.reveal-delay-4 { animation-delay: 0.8s; }
.reveal-delay-5 { animation-delay: 1s; }

.pulse-glow {
    animation: pulse-glow 2s ease-in-out infinite;
}

.hero {
    position: relative;
    overflow: hidden;
}

.hero::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(212,175,55,0.05) 0%, transparent 70%);
    animation: float 20s ease-in-out infinite;
    pointer-events: none;
}

.hero-text h1 {
    animation: slide-up 1s ease forwards;
}

.hero-media {
    animation: float 4s ease-in-out infinite;
}

.grid {
    perspective: 1000px;
}

.grid.cards-4 .card {
    transition: var(--transition-smooth);
}

.grid.cards-4 .card:nth-child(1) { animation: slide-up 0.6s ease forwards; }
.grid.cards-4 .card:nth-child(2) { animation: slide-up 0.7s ease forwards; }
.grid.cards-4 .card:nth-child(3) { animation: slide-up 0.8s ease forwards; }
.grid.cards-4 .card:nth-child(4) { animation: slide-up 0.9s ease forwards; }

.glass {
    background: rgba(30, 30, 40, 0.4);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1.5px solid rgba(212, 175, 55, 0.2);
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3),
                inset 0 1px 1px rgba(255, 255, 255, 0.2),
                0 0 20px rgba(212, 175, 55, 0.1);
    transition: var(--transition-smooth);
    position: relative;
    overflow: hidden;
}

.glass::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(212,175,55,0.1) 0%, transparent 100%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
}

.glass:hover {
    background: rgba(30, 30, 40, 0.6);
    border-color: rgba(212, 175, 55, 0.4);
    box-shadow: 0 12px 40px rgba(212, 175, 55, 0.2),
                inset 0 1px 1px rgba(255, 255, 255, 0.3),
                0 0 30px rgba(212, 175, 55, 0.15);
    transform: translateY(-8px);
}

.glass:hover::before {
    opacity: 1;
}

.container {
    position: relative;
}

input, textarea, select {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(212, 175, 55, 0.2);
    color: #f5f5f5;
    transition: var(--transition-smooth);
    border-radius: 8px;
}

input:focus, textarea:focus, select:focus {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(212, 175, 55, 0.6);
    box-shadow: 0 0 20px rgba(212, 175, 55, 0.3),
                inset 0 0 10px rgba(212, 175, 55, 0.1);
    outline: none;
}

h1, h2, h3, h4, h5, h6 {
    transition: var(--transition-smooth);
}

h1:hover, h2:hover, h3:hover {
    text-shadow: 0 0 20px rgba(212, 175, 55, 0.4),
                 0 0 40px rgba(212, 175, 55, 0.2);
    transform: scale(1.02);
}

a {
    transition: var(--transition-smooth);
    position: relative;
}

footer {
    border-top: 1px solid rgba(212, 175, 55, 0.1);
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(10px);
}

@media (max-width: 768px) {
    .card {
        padding: 1rem;
    }
    
    .glass {
        padding: 1.5rem;
    }
    
    nav ul li a {
        padding: 8px 12px;
        font-size: 16px;
    }
    
    h1 { font-size: 1.8rem; }
    h2 { font-size: 1.4rem; }
    h3 { font-size: 1.2rem; }
    
    .card:hover {
        transform: translateY(-8px) scale(1.02);
    }
    
    nav ul li a:hover {
        transform: translateY(-2px) scale(1.1);
    }
}

@media (max-width: 480px){
    .cards-4{grid-template-columns:1fr}
    .container{padding:1rem}
    .hero-text h1{font-size:1.4rem}
    
    .card:hover {
        transform: translateY(-4px) scale(1.01);
    }
    
    nav ul li a:hover {
        transform: scale(1.05);
    }
    
    .btn:hover {
        transform: scale(1.04) translateY(-1px);
    }
}



.stats {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
    background: #000000;
    padding: 3rem;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.8),
                inset 0 1px 0 rgba(212, 175, 55, 0.2);
    border: 1px solid rgba(212, 175, 55, 0.15);
    margin-top: 2rem;
}

.stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
    transition: var(--transition-smooth);
    padding: 1.5rem;
}

.stat strong {
    font-size: 2.5rem;
    color: var(--gold);
    font-weight: 700;
    transition: var(--transition-smooth);
    text-shadow: 0 0 20px rgba(212, 175, 55, 0.4);
}

.stat span {
    font-size: 1rem;
    color: #f5f5f5;
    font-weight: 500;
    letter-spacing: 0.5px;
    transition: var(--transition-smooth);
}

.stat:hover {
    transform: scale(1.12) translateY(-8px);
}

.stat:hover strong {
    font-size: 3rem;
    text-shadow: 0 0 30px rgba(212, 175, 55, 0.6),
                 0 0 60px rgba(212, 175, 55, 0.3);
}

.stat:hover span {
    color: var(--gold);
    letter-spacing: 1px;
}

@media (max-width: 768px) {
    .stats {
        gap: 30px;
        padding: 2rem;
    }
    
    .stat {
        padding: 1rem;
    }
    
    .stat strong {
        font-size: 2rem;
    }
}

@media (max-width: 480px) {
    .stats {
        gap: 20px;
        padding: 1.5rem;
        flex-direction: column;
    }
    
    .stat strong {
        font-size: 1.8rem;
    }
    
    .stat:hover {
        transform: scale(1.08) translateY(-4px);
    }
}



.nav-link {
    position: relative;
    overflow: hidden;
    transition: var(--transition-smooth);
    padding: 8px 12px;
    border-radius: 8px;
    display: inline-block;
}

.nav-link::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, rgba(212,175,55,0.25), transparent);
    transition: left 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    z-index: -1;
}

.nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0%;
    height: 2px;
    background: linear-gradient(90deg, var(--gold), #f5d547);
    transition: width 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    transform: translateX(-50%);
    border-radius: 10px;
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
}

.nav-link:hover {
    color: var(--gold);
    transform: translateY(-3px) scale(1.05);
    text-shadow: 0 0 12px rgba(212, 175, 55, 0.6);
    background: rgba(212, 175, 55, 0.08);
}

.nav-link:hover::before {
    left: 100%;
}

.nav-link:hover::after {
    width: 100%;
}

.nav-link-btn {
    transition: var(--transition-smooth);
    position: relative;
    overflow: visible;
}

.nav-link-btn:hover {
    transform: translateY(-4px) scale(1.08);
    box-shadow: 0 0 25px rgba(212, 175, 55, 0.4);
}

@media (max-width: 800px) {
    .nav-link {
        padding: 8px 10px;
        font-size: 0.95rem;
    }
    
    .nav-link:hover {
        transform: translateY(-2px) scale(1.03);
    }
}

@media (max-width: 480px) {
    .nav-link {
        padding: 6px 8px;
        font-size: 0.9rem;
    }
    
    .nav-link:hover {
        transform: scale(1.02);
    }
}





